<Ui xmlns="http://www.blizzard.com/wow/ui/"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
	<Frame name="CodexExampleAddonPanel" parent="UIParent" hidden="true">
		<Size x="680" y="520"/>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentTitle" inherits="GameFontNormalLarge" text="Inority Instance Tracker">
					<Anchors>
						<Anchor point="TOP" x="0" y="-16"/>
					</Anchors>
				</FontString>
				<FontString name="$parentSubtitle" inherits="GameFontHighlightSmall" text="Lightweight saved instance tracker for your characters.">
					<Anchors>
						<Anchor point="TOP" relativeTo="$parentTitle" relativePoint="BOTTOM" x="0" y="-8"/>
					</Anchors>
				</FontString>
				<FontString name="$parentNavHeader" inherits="GameFontNormal" text="Sections">
					<Anchors>
						<Anchor point="TOPLEFT" x="24" y="-62"/>
					</Anchors>
				</FontString>
				<Texture name="$parentNavDivider">
					<Anchors>
						<Anchor point="TOPLEFT" x="136" y="-58"/>
						<Anchor point="BOTTOMLEFT" x="136" y="26"/>
					</Anchors>
					<Color r="0.22" g="0.24" b="0.30" a="0.95"/>
				</Texture>
				<FontString name="$parentConfigHeader" inherits="GameFontNormal" text="Config">
					<Anchors>
						<Anchor point="TOPLEFT" x="156" y="-62"/>
					</Anchors>
				</FontString>
				<FontString name="$parentConfigFiltersHeader" inherits="GameFontHighlight" text="Tracking Filters">
					<Anchors>
						<Anchor point="TOPLEFT" x="156" y="-92"/>
					</Anchors>
				</FontString>
				<FontString name="$parentConfigLootHeader" inherits="GameFontHighlight" text="Loot Display">
					<Anchors>
						<Anchor point="TOPLEFT" x="420" y="-92"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTrackHeader" inherits="GameFontNormal" text="Tracked Lockouts">
					<Anchors>
						<Anchor point="TOPLEFT" x="156" y="-62"/>
					</Anchors>
				</FontString>
				<FontString name="$parentClassHeader" inherits="GameFontNormal" text="Classes">
					<Anchors>
						<Anchor point="TOPLEFT" x="500" y="-62"/>
					</Anchors>
				</FontString>
				<FontString name="$parentItemHeader" inherits="GameFontNormal" text="Item Types">
					<Anchors>
						<Anchor point="TOPLEFT" x="156" y="-62"/>
					</Anchors>
				</FontString>
				<FontString name="$parentListHeader" inherits="GameFontNormal" text="Tracked Lockouts">
					<Anchors>
						<Anchor point="TOPLEFT" x="156" y="-214"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentCloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT" x="-6" y="-5"/>
				</Anchors>
			</Button>
			<Button name="$parentNavConfigButton" inherits="UIPanelButtonTemplate" text="Config">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="24" y="-84"/>
				</Anchors>
			</Button>
			<Button name="$parentNavTrackButton" inherits="UIPanelButtonTemplate" text="Tracking">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentNavConfigButton" relativePoint="BOTTOMLEFT" x="0" y="-8"/>
				</Anchors>
			</Button>
			<Button name="$parentNavClassButton" inherits="UIPanelButtonTemplate" text="Classes">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentNavTrackButton" relativePoint="BOTTOMLEFT" x="0" y="-8"/>
				</Anchors>
			</Button>
			<Button name="$parentNavLootButton" inherits="UIPanelButtonTemplate" text="Loot">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentNavClassButton" relativePoint="BOTTOMLEFT" x="0" y="-8"/>
				</Anchors>
			</Button>
			<Button name="$parentNavDebugButton" inherits="UIPanelButtonTemplate" text="Debug">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentNavLootButton" relativePoint="BOTTOMLEFT" x="0" y="-8"/>
				</Anchors>
			</Button>
			<CheckButton name="$parentCheckbox1" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="156" y="-116"/>
				</Anchors>
			</CheckButton>
			<CheckButton name="$parentCheckbox2" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="156" y="-140"/>
				</Anchors>
			</CheckButton>
			<CheckButton name="$parentCheckbox3" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="156" y="-164"/>
				</Anchors>
			</CheckButton>
			<CheckButton name="$parentCheckbox4" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="420" y="-116"/>
				</Anchors>
			</CheckButton>
			<CheckButton name="$parentCheckbox5" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="420" y="-140"/>
				</Anchors>
			</CheckButton>
			<Slider name="$parentSlider" inherits="OptionsSliderTemplate" minValue="0" maxValue="100" valueStep="1">
				<Size x="220" y="16"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="156" y="-214"/>
				</Anchors>
			</Slider>
			<ScrollFrame name="$parentClassScrollFrame" inherits="UIPanelScrollFrameTemplate">
				<Size x="156" y="112"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="500" y="-84"/>
				</Anchors>
			</ScrollFrame>
			<Frame name="$parentClassScrollChild">
				<Size x="132" y="112"/>
				<Anchors>
					<Anchor point="TOPLEFT"/>
				</Anchors>
			</Frame>
			<Button name="$parentTransmogButton" inherits="UIPanelButtonTemplate" text="Transmog">
				<Size x="132" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="156" y="-84"/>
				</Anchors>
			</Button>
			<ScrollFrame name="$parentItemScrollFrame" inherits="UIPanelScrollFrameTemplate">
				<Size x="220" y="328"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="156" y="-116"/>
				</Anchors>
			</ScrollFrame>
			<Frame name="$parentItemScrollChild">
				<Size x="196" y="328"/>
				<Anchors>
					<Anchor point="TOPLEFT"/>
				</Anchors>
			</Frame>
			<ScrollFrame name="$parentScrollFrame" inherits="UIPanelScrollFrameTemplate">
				<Size x="500" y="236"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="156" y="-238"/>
				</Anchors>
			</ScrollFrame>
			<EditBox name="$parentScrollChild">
				<Size x="478" y="236"/>
				<Anchors>
					<Anchor point="TOPLEFT"/>
				</Anchors>
				<FontString inherits="GameFontHighlightSmall"/>
			</EditBox>
			<Button name="$parentRefreshButton" inherits="UIPanelButtonTemplate" text="Refresh">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="BOTTOMRIGHT" x="-24" y="20"/>
				</Anchors>
			</Button>
			<Button name="$parentResetButton" inherits="UIPanelButtonTemplate" text="Clear Data">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="RIGHT" relativeTo="$parentRefreshButton" relativePoint="LEFT" x="-8" y="0"/>
				</Anchors>
			</Button>
		</Frames>
	</Frame>
</Ui>
