<Ui xmlns="http://www.blizzard.com/wow/ui/"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
	<Frame name="CodexExampleAddonPanel" parent="UIParent" hidden="true">
		<Size x="360" y="260"/>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentTitle" inherits="GameFontNormalLarge" text="Codex Example Addon">
					<Anchors>
						<Anchor point="TOP" x="0" y="-16"/>
					</Anchors>
				</FontString>
				<FontString name="$parentSubtitle" inherits="GameFontHighlightSmall" text="Sample settings panel with placeholder options.">
					<Anchors>
						<Anchor point="TOP" relativeTo="$parentTitle" relativePoint="BOTTOM" x="0" y="-8"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentCloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT" x="-6" y="-5"/>
				</Anchors>
			</Button>
			<CheckButton name="$parentCheckbox1" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="24" y="-64"/>
				</Anchors>
			</CheckButton>
			<CheckButton name="$parentCheckbox2" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="24" y="-96"/>
				</Anchors>
			</CheckButton>
			<CheckButton name="$parentCheckbox3" inherits="UICheckButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="24" y="-128"/>
				</Anchors>
			</CheckButton>
			<Slider name="$parentSlider" inherits="OptionsSliderTemplate" minValue="0" maxValue="100" valueStep="1">
				<Size x="220" y="16"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="24" y="-180"/>
				</Anchors>
			</Slider>
			<Button name="$parentApplyButton" inherits="UIPanelButtonTemplate" text="Apply">
				<Size x="96" y="24"/>
				<Anchors>
					<Anchor point="BOTTOMRIGHT" x="-24" y="20"/>
				</Anchors>
			</Button>
		</Frames>
	</Frame>
</Ui>
