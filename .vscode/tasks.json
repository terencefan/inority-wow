{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MogTracker: check",
      "type": "shell",
      "command": "bash",
      "args": [
        "./tools/check.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MogTracker: check (skip format)",
      "type": "shell",
      "command": "bash",
      "args": [
        "./tools/check.sh",
        "--skip-format"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MogTracker: luacheck",
      "type": "shell",
      "command": "bash",
      "args": [
        "./tools/run_luacheck.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MogTracker: jscpd",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\tools\\run_jscpd.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MogTracker: LuaLS",
      "type": "shell",
      "command": "bash",
      "args": [
        "./tools/run_luals_check.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MogTracker: tests",
      "type": "shell",
      "command": "bash",
      "args": [
        "./tools/run_lua_tests.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
